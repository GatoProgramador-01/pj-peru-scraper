    {
      "id": "phase2-body", "type": "text", "x": 45, "y": 1005, "width": 1280, "height": 185,
      "angle": 0, "strokeColor": "#14532d", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "groupIds": [], "frameId": null, "roundness": null, "seed": 252,
      "version": 1, "versionNonce": 1, "isDeleted": false, "boundElements": null,
      "updated": 1, "link": null, "locked": false,
      "text": "Lee all-districts.jsonl línea por línea  →  extrae pdfUrl  →  descarga en lote\n\n[doc 1 pdfUrl] ──────────────────────────────────────────────── GET /ServletDescarga?uuid=A → pdfs/A.pdf\n[doc 2 pdfUrl] ──────────────────────────────────────────────── GET /ServletDescarga?uuid=B → pdfs/B.pdf\n[doc 3 pdfUrl] ──────────────────────────────────────────────── GET /ServletDescarga?uuid=C → pdfs/C.pdf\n· · ·\n[doc N pdfUrl] ──────────────────────────────────────────────── GET /ServletDescarga?uuid=N → pdfs/N.pdf\n\n50 descargas concurrentes  |  cookies pre-cargadas  |  skip si ya existe en disco\n⚡  459k PDFs × 2s / 50 conc = ~5h  vs 41h por distrito acoplado",
      "fontSize": 14, "fontFamily": 2, "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "originalText": "Lee all-districts.jsonl línea por línea  →  extrae pdfUrl  →  descarga en lote\n\n[doc 1 pdfUrl] ──────────────────────────────────────────────── GET /ServletDescarga?uuid=A → pdfs/A.pdf\n[doc 2 pdfUrl] ──────────────────────────────────────────────── GET /ServletDescarga?uuid=B → pdfs/B.pdf\n[doc 3 pdfUrl] ──────────────────────────────────────────────── GET /ServletDescarga?uuid=C → pdfs/C.pdf\n· · ·\n[doc N pdfUrl] ──────────────────────────────────────────────── GET /ServletDescarga?uuid=N → pdfs/N.pdf\n\n50 descargas concurrentes  |  cookies pre-cargadas  |  skip si ya existe en disco\n⚡  459k PDFs × 2s / 50 conc = ~5h  vs 41h por distrito acoplado",
      "lineHeight": 1.25
    },

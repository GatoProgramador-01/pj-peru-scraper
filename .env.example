# ─── Variables de entorno opcionales ──────────────────────────────────────────
#
# Todas tienen valores por defecto. Copiar a .env y ajustar solo lo necesario.
# Ninguna de estas variables contiene secretos; el scraper no requiere credenciales.
#
# Uso: cp .env.example .env  — el scraper lo carga automaticamente al arrancar.
#
# ─── Descarga de PDFs ──────────────────────────────────────────────────────────

# Descargas concurrentes de PDF por lote de pagina (por defecto: 1).
# Subir a 4-10 para OEFA; mantener en 1-5 para PJ Peru para evitar soft-blocks.
PDF_CONCURRENCY=4

# ─── probe:oefa:429 — sonda de rate limiting ───────────────────────────────────
# Solo correr contra el portal real. NO incluir en CI.
# Comando: npm run probe:oefa:429

# URL del portal a sondear.
PROBE_429_URL=https://publico.oefa.gob.pe/repdig/consulta/consultaTfa.xhtml

# Total de requests a enviar en la sonda.
PROBE_429_TOTAL=500

# Requests concurrentes por lote.
PROBE_429_CONCURRENCY=20

# Detener al primer 429 recibido ('false' para seguir contando, por defecto: 'true').
PROBE_429_STOP_ON_FIRST=true

# Ruta del reporte JSON de salida.
PROBE_429_OUT=output/test429/probe429.json

# Modo de request: 'search' = POST formulario JSF completo (mas realista),
# 'get' = GET simple (mas rapido, menos representativo del uso real).
PROBE_429_MODE=search
